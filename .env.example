# ============================================
# DATA LAKEHOUSE - Environment Variables
# ============================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to Git!

# ─── PostgreSQL (ERP Source Database) ───────
PG_HOST=localhost
PG_PORT=5433
PG_DB=erp_source
PG_USER=erp_user
PG_PASSWORD=your_password_here

# ─── MySQL (Data Lakehouse) ─────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=data_lakehouse
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here

# ─── Pipeline Configuration ─────────────────
BATCH_SIZE=1000
LOG_LEVEL=INFO
ENABLE_LOGGING=true

# ─── AWS (if migrating to cloud) ────────────
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET=your-data-lakehouse-bucket

# ─── Airflow (if using orchestration) ───────
# AIRFLOW_HOME=/path/to/airflow
# AIRFLOW__CORE__EXECUTOR=LocalExecutor
# AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost/airflow

# ─── Monitoring & Alerting ──────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=alerts@yourdomain.com
# EMAIL_TO=team@yourdomain.com
